# =============================================================================
# Mail-in-a-Docker Environment Configuration
# Copy this file to .env and adjust values for your deployment.
# =============================================================================

# Primary mail hostname (FQDN) — must resolve to your server's public IP
PRIMARY_HOSTNAME=mail.example.com

# Storage path for mail data, SSL certificates, DNS zones, etc.
STORAGE_ROOT=./data

# Timezone for the container
TIMEZONE=Etc/UTC

# Docker container name
CONTAINER_NAME=miad

# Port mappings (host:container) — change only if you have conflicts
SMTP_PORT=25
SUBMISSION_PORT=587
SMTPS_PORT=465
IMAPS_PORT=993
POP3S_PORT=995
SIEVE_PORT=4190
SPAMPD_PORT=10025
HTTP_PORT=810
HTTPS_PORT=4413
